{
  "name": "c2pulse devcontainer",
  "image": "ghcr.io/fstarlang/c2pulse-devcontainer",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "ccls-project.ccls",
        "FStarLang.fstar-vscode-assistant"
      ]
    }
  },
  "remoteEnv": {
  },
  // Runs only once when container is prepared
  "onCreateCommand": {
    "restore-opt-cache": "cd /workspaces/c2pulse && test ! -f opt/opam.done && tar -xf /c2pulse-opt-cache.tar.zst || echo not using cache"
  },
  // Runs periodically and/or when content of repo changes
  "updateContentCommand": {
  },
  // These run only when the container is assigned to a user
  "postCreateCommand": {
  }
}
